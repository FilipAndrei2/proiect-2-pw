<section class="panel auth-panel">
  <h2>Autentificare</h2>

  <% if (blockedMs) { %>
    <p class="error">
      Ai depășit numărul de încercări permise. Încearcă din nou peste
      <%= Math.ceil(blockedMs / 60000) %> minute.
    </p>
  <% } %>

  <% if (!blockedMs && errorMessage) { %>
    <p class="error"><%= errorMessage %></p>
  <% } %>

  <% if (!blockedMs) { %>
    <form action="/verificare-autentificare" method="POST" class="form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        Utilizator
        <input type="text" name="username" required />
      </label>
      <label>
        Parolă
        <input type="password" name="password" required />
      </label>
      <button type="submit">Autentificare</button>
    </form>
  <% } %>
</section>
